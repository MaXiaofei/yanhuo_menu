# 部署密钥模板 —— 复制为 .env.dev 后填入真实值
# 本文件可提交；.env.dev 已被 .gitignore 忽略，切勿提交。
# 说明见 docs/deploy.md「〇、环境划分」

# ============ 测试环境（腾讯云，与生产同机隔离）============
# 测试环境已从内网迁移到生产服务器，与生产通过独立 project/网络/容器名/端口隔离，
# 详见 docs/deploy.md「〇、环境划分」。
STAGING_SSH_HOST=<测试服务器 IP>
STAGING_SSH_USER=<SSH 用户名>
STAGING_SSH_PASS=<SSH 密码>
STAGING_MYSQL_ROOT_PASSWORD=<测试库密码,建议与生产不同>
STAGING_DEEPSEEK_API_KEY=<可选,留空则 AI 走 mock>
STAGING_GLM_API_KEY=<可选>
STAGING_AI_PROVIDER=mock

# ============ 生产环境（腾讯云）============
SSH_HOST=<生产服务器 IP>
SSH_USER=<SSH 用户名>
SSH_PASS=<SSH 密码>
DEEPSEEK_API_KEY=<DeepSeek API Key>
GLM_API_KEY=<智谱 GLM API Key,可选>
MYSQL_ROOT_PASSWORD=<生产环境 MySQL root 密码>

# ============ 腾讯云 API 密钥（用于自动化运维）============
TENCENT_SECRET_ID=<腾讯云 SecretId>
TENCENT_SECRET_KEY=<腾讯云 SecretKey>

# 说明：DeepSeek key 变量名现为 DEEPSEEK_API_KEY。
# 为兼容旧部署机器仍写 API_KEY 的情况，docker-compose 用 ${DEEPSEEK_API_KEY:-${API_KEY:-}} 透传，
# yml 用 ${DEEPSEEK_API_KEY:${API_KEY:}} 回退读取。新旧名都能识别，无需立即改部署机。
